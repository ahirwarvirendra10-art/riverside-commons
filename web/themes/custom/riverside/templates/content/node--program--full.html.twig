{#
/**
 * @file
 * Program full page.
 */
#}

<article class="program-detail">

	<div class="program-header">

		<h1 class="program-title">
			{{ label }}
		</h1>

		{% if content.field_subtitle %}
			<div class="program-subtitle">
				{{ content.field_subtitle }}
			</div>
		{% endif %}

	</div>

	<div class="detail-body">

		<div class="main-content">

			<div class="program-hero">
				{{content.field_hero_image}}
			</div>

			<div class="program-body">
				{{ content.body }}
			</div>

			<section class="program-instructor">

				<h2 class="program-section-title">
					Your Instructor
				</h2>

				<div class="program-instructor-wrapper">

					<div class="program-instructor-image">
						{{ content.field_instructor_photo }}
					</div>

					<div class="program-instructor-content">

						<h3 class="program-instructor-name">
							{{ content.field_instructor_name }}
						</h3>

						<div class="program-instructor-role">
							Resident ceramic artist since 2014
						</div>

						<div class="program-instructor-bio">
							{{ content.field_instructor_bio }}
						</div>

					</div>

				</div>

			</section>

		</div>

		<aside class="info-card">

			<div class="price-block">
				<h2 class="program-price">
					${{ node.field_standard_price.value }}
				</h2>

				<p class="member-price">
					{{ node.field_sessions.value }}
					· member price ${{ node.field_member_price.value }}
				</p>

			</div>

			<div class="program-details">

				<div class="detail-row">
					<span class="detail-label">Level</span>
					<span class="detail-value">{{ content.field_level }}</span>
				</div>

				<div class="detail-row">
					<span class="detail-label">Schedule</span>
					<span class="detail-value">{{ content.field_schedule }}</span>
				</div>

				<div class="detail-row">
					<span class="detail-label">Dates</span>
					<span class="detail-value">
						{{ content.field_start_date }}
						–
						{{ content.field_end_date }}
					</span>
				</div>

				<div class="detail-row">
					<span class="detail-label">Sessions</span>
					<span class="detail-value">{{ content.field_sessions }}</span>
				</div>

				<div class="detail-row">
					<span class="detail-label">Class size</span>
					<span class="detail-value">{{ content.field_class_size }}</span>
				</div>

				<div class="detail-row">
					<span class="detail-label">Location</span>
					<span class="detail-value">{{ content.field_location }}</span>
				</div>

			</div>
			<a href="#" class="btn-primary">
				Register
			</a>
			<a href="#" class="btn-secondary">
				Add to wishlist
			</a>
			<p class="info-note">
				Free cancellation up to 7 days before the first class.
			</p>
		</aside>

	</div>
	<section class="related-programs">
		<h2 class="program-section-title">
			More Studio Classes
		</h2>
		{{ content.field_related_programs }}
	</section>
</article>
