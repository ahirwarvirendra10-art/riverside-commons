<article class="program-card">

	<div class="program-card__image">
		{% if node.field_hero_images[0].entity.uri.value %}
			<a href="{{ url }}">
				<img src="{{ file_url(node.field_hero_images[0].entity.uri.value) }}" alt="{{ node.field_hero_images[0].alt|default(label) }}" class="program-card__img"/>
			</a>
		{% endif %}
	</div>

	<div class="program-card__content">

		<div class="program-card__category">
			{{ node.field_program_category.entity.label }}
		</div>

		<h3 class="program-card__title">
			<a href="{{ url }}">{{ label }}</a>
		</h3>

		{% if content.body %}
			<div class="program-card__description">
				{{ content.body }}
			</div>
		{% elseif content.field_description %}
			<div class="program-card__description">
				{{ content.field_description }}
			</div>
		{% endif %}

		<div class="program-card__description">
			{{ node.field_card_description.value }}
		</div>

		<div class="program-card__meta">
			{{ node.field_sessions.value }}
			•
			{{ node.field_schedule.value }}
			•
			  ${{ node.field_standard_price.value }}
		</div>

	</div>

</article>
